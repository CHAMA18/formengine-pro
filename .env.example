# ===========================================
# FormEngine Pro — Environment Variables
# ===========================================
# Copy this file to .env and adjust the values.

# --- Database (PostgreSQL) ---
# Local Docker Compose (from your host machine):
DATABASE_URL="postgresql://fep:fep_password@localhost:5432/formengine?schema=public"
#
# Docker internal (app container → db container — use this if running both in Docker):
# DATABASE_URL="postgresql://fep:fep_password@db:5432/formengine?schema=public"
#
# External PostgreSQL (e.g. Supabase, Neon, RDS):
# DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# Note: Authentication uses the app's own database-backed auth system
# (email/password + guest sign-in). No third-party OAuth providers are
# used, so no client IDs or secrets are required.
