generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String
  fullName      String?
  orgName       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  forms         Form[]
  apiKeys       ApiKey[]
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Form {
  id          String   @id @default(cuid())
  shareId     String   @unique @default(cuid())
  name        String
  description String?
  flowchart   Json
  schema      Json
  status      String   @default("draft")
  ownerId     String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  submissions Submission[]

  @@index([status])
  @@index([createdAt])
  @@index([ownerId])
}

model Submission {
  id        DateTime @id @default(now())
  formId    String
  data      Json
  source    String?
  status    String   @default("Live")
  form      Form     @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId])
  @@index([status])
  @@index([id])
}

model ApiKey {
  id            String    @id @default(cuid())
  name          String
  keyHash       String    @unique
  keyPrefix     String
  status        String    @default("active")
  permissions   Json      @default("[]")
  ownerId       String
  lastRotatedAt DateTime?
  lastUsedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  owner         User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([keyHash])
  @@index([ownerId])
}

model Session {
  id          String   @id @default(cuid())
  token       String   @unique
  userId      String
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}
